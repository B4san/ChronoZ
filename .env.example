# Chronos Engine — Environment Variables

# OpenRouter (Required)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
OPENROUTER_SITE_URL=https://your-site.com
OPENROUTER_SITE_TITLE=ChronoZ

# Model Overrides (optional - defaults to openrouter/free)
# OPENROUTER_TIMELINE_MODEL=openrouter/free
# OPENROUTER_ENTITY_MODEL=openrouter/free
# OPENROUTER_PARSER_MODEL=openrouter/free

# Neo4j (Phase 2+)
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password

# Redis (Phase 2+)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Auth (Phase 2+)
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000
