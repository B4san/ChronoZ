# Chronos Engine — Environment Variables

# LLM Providers
# Option 1: OpenRouter (Recommended - single API key for all models)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
OPENROUTER_SITE_URL=https://your-site.com
OPENROUTER_SITE_TITLE=ChronoZ

# Option 2: Direct Provider Keys (fallback when no OpenRouter)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Model Overrides (optional - defaults to best available)
# OPENROUTER_TIMELINE_MODEL=anthropic/claude-sonnet-4-20250514
# OPENROUTER_ENTITY_MODEL=openai/gpt-4o
# OPENROUTER_PARSER_MODEL=openai/gpt-4o-mini
# OPENROUTER_FALLBACK_MODEL=openai/gpt-4o-mini

# Neo4j (Phase 2+)
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password

# Redis (Phase 2+)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Auth (Phase 2+)
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000
